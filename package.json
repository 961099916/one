{
  "name": "one",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "One AI - 本地 LLM 聊天应用（端侧离线版）",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/961099916/one.git"
  },
  "author": "",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build && electron-builder",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "format": "prettier --write src/ electron/",
    "format:check": "prettier --check src/ electron/",
    "check": "npm run type-check && npm run lint:check && npm run format:check",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "@vicons/ionicons5": "^0.13.0",
    "@vueuse/core": "^10.9.0",
    "better-sqlite3": "^12.8.0",
    "dexie": "^4.4.2",
    "electron-log": "^5.1.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "lodash-es": "^4.17.21",
    "markdown-it": "^14.1.1",
    "naive-ui": "^2.38.1",
    "node-cron": "^4.2.1",
    "node-llama-cpp": "^3.18.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/highlight.js": "^9.12.4",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.23.0",
    "postcss": "^8.5.9",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-eslint-parser": "^9.4.2",
    "vue-tsc": "^2.0.26"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "electron",
    "vue",
    "vite",
    "llm",
    "ai",
    "offline",
    "local-first"
  ]
}
